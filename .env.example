# Copy file này thành .env rồi điền thông tin thật
# cp .env.example .env

# Django
SECRET_KEY=your-very-secret-key-change-this
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost

# Database — dùng "db" (tên service Docker), không phải "localhost"
DATABASE_URL=postgresql://postgres:your-db-password@db:5432/hrm_db
DB_PASSWORD=your-db-password

# Celery — dùng Redis service trong Docker
CELERY_BROKER_URL=redis://redis:6379/0

# Logging level: WARNING (production) hoặc DEBUG (development)
DJANGO_LOG_LEVEL=WARNING

# Copy file này thành .env rồi điền thông tin thật
# cp .env.example .env

# ============================================================
# DJANGO
# ============================================================

# Tạo SECRET_KEY mới bằng lệnh:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-very-secret-key-change-this

DEBUG=False

# Điền IP VPS hoặc tên miền (không có http://)
# Ví dụ: ALLOWED_HOSTS=123.456.789.0,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Điền đầy đủ URL gồm http:// hoặc https://
# Ví dụ: CSRF_TRUSTED_ORIGINS=http://123.456.789.0
CSRF_TRUSTED_ORIGINS=http://localhost

# ============================================================
# DATABASE — dùng "db" (tên service Docker), không phải "localhost"
# ============================================================
DATABASE_URL=postgresql://postgres:your-db-password@db:5432/hrm_db
DB_PASSWORD=your-db-password

# ============================================================
# CELERY — dùng Redis service trong Docker
# ============================================================
CELERY_BROKER_URL=redis://redis:6379/0

# ============================================================
# LOGGING — WARNING (production) hoặc DEBUG (development)
# ============================================================
DJANGO_LOG_LEVEL=WARNING
